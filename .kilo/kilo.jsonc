{
  "$schema": "https://app.kilo.ai/config.json",
  "username": "Universal Dev",
  "default_agent": "dev",
  "instructions": [
    "AGENTS.md",
    ".kilo/instructions/*.md"
  ],
  "auto_collapse_reasoning": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
    "tail_turns": 2
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "write": "allow",
    "question": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "task": {
      "*": "allow"
    },
    "bash": {
      "echo*": "allow",
      "uname*": "allow",
      "which*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "curl*": "allow",
      "wget*": "allow",
      "git*": "allow",
      "make*": "allow",
      "uv*": "allow",
      "pip*": "allow",
      "npm*": "allow",
      "npx*": "allow",
      "python3*": "allow",
      "node*": "allow",
      "docker*": "allow",
      "date*": "allow",
      "pwd*": "allow",
      "df*": "allow",
      "stat*": "allow",
      "mkdir*": "allow",
      "touch*": "allow",
      "cp*": "allow",
      "mv*": "allow",
      "source*": "allow",
      "sudo apt-get update": "ask",
      "sudo apt-get install*": "ask",
      "sudo apt*": "ask",
      "sudo rm *": "deny",
      "sudo rm -rf /*": "deny",
      "sudo rm -rf /": "deny",
      "sudo dd *": "deny",
      "sudo mkfs*": "deny",
      "sudo poweroff": "deny",
      "sudo reboot": "deny",
      "sudo shutdown": "deny",
      "sudo kill -9 *": "deny",
      "sudo chmod 0*": "deny",
      "sudo chown root*": "deny",
      "*": "ask"
    },
    "external_directory": {
      "/tmp/*": "allow",
      "/opt/*": "allow",
      "/etc/*": "allow",
      "/usr/local/*": "allow",
      "/var/log/*": "allow",
      "*": "ask"
    }
  }
}
