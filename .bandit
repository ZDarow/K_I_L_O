# Bandit security linter configuration
# See: https://bandit.readthedocs.io/en/latest/config.html

skips: ['B101']  # allow assert statements in tests
tests:
  - B201  # flask debug
  - B301  # pickle
  - B302  # marshal
  - B303  # md5
  - B304  # ciphers
  - B305  # cipher modes
  - B306  # mktemp_q
  - B307  # eval
  - B308  # mark_safe
  - B309  # httpsconnection
  - B310  # urllib_urlopen
  - B311  # random
  - B312  # telnetlib
  - B313  # xml_bad_cElementTree
  - B314  # xml_bad_ElementTree
  - B315  # xml_bad_expatreader
  - B316  # xml_bad_minidom
  - B317  # xml_bad_pulldom
  - B318  # xml_bad_sax
  - B319  # xml_bad_etree
  - B320  # sql_injection
  - B321  # ftp
  - B322  # input
  - B323  # unverified_context
  - B324  # hashlib_new_insecure_functions
  - B325  # temp_file

exclude_dirs:
  - '.venv'
  - '.git'
  - '__pycache__'
  - 'node_modules'
  - '.kilo'
  - 'src/kilo-config'
  - 'ble-project'
  - '.config'
