# ─── Dot-файлы: по умолчанию игнорируем, точечно разрешаем ─
.*

# Разрешённые dot-директории
!.gitignore
!.githooks/
!.kilo/
!.kilocode/
!.config/
!.github/
!.vscode/
!.yamllint.yml
!.editorconfig
!.pre-commit-config.yaml
!.shellcheckrc
!.markdownlint.yml
!.nvmrc
!.python-version
!.uv.toml
!.gitlint
!.bandit
!.gitattributes
!CITATION.cff
!.actrc
!docker/.dockerignore

# Разрешённые dot-директории
.config/*
!.config/kilo/

# ─── Директории репозитория ───────────────────────
!AGENTS.md
!Makefile
!README.md
!install.sh
!LICENSE
!scripts/
!src/
!docs/
!tests/
!docker/
!gui/

# ─── Ветка BLE — не трекать на master ────────────
ble-project/

# ─── Артефакты разработки ─────────────────────────
node_modules/
__pycache__/
*.pyc
.venv/
.uv-cache/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ─── Установочные артефакты пакетов ─────────────
*.egg-info/
*.egg
*~
*.swp
*.swo
*.bak
*.log

# ─── Бинарные пакеты и медиа ─────────────────────
*.deb
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.pdf
