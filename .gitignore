# Системные и пользовательские файлы (домашняя директория)
.*
!.gitignore
!.githooks/
!.kilo/

# Kilo-конфиг внутри .config/ (остальное игнорируется)
!.config/
.config/*
!.config/kilo/

# Репозиторий установщика — отслеживаемые файлы
!AGENTS.md
!Makefile
!README.md
!install.sh
!LICENSE

# Dot-файлы конфигурации
!.yamllint.yml
!.editorconfig
!.pre-commit-config.yaml
!.shellcheckrc
!.markdownlint.yml
!.nvmrc
!.python-version
!.uv.toml

# uv кэш (не трекать)
.uv-cache/

# Директории репозитория
!scripts/
!src/
!docs/
!.github/
!tests/
!docker/

# Артефакты разработки
node_modules/
__pycache__/
*.pyc
.venv/

# Временные и кэш-файлы
*~
*.swp
*.swo
*.bak

# Логи
*.log

# Бинарные пакеты и медиа
*.deb
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.pdf

# Пользовательские директории и файлы (НЕ для git)
/Pro_logy/
/v2rayN-russia-setup/
/backup Linux/
/Загрузки/
/Изображения/
/Рабочий стол/
/check_kilocode.sh
/full_network_diag.sh
/network_full_diag.sh
/port_dpi_check.sh
/my_report.txt
