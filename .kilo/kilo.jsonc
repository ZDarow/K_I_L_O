{
  "$schema": "https://app.kilo.ai/config.json",
  "username": "BLE Engineer",
  "default_agent": "ble-engineer",
  "model": "anthropic/claude-sonnet-4-20250514",
  "instructions": [".kilo/instructions/*.md"],
  "auto_collapse_reasoning": true,
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "bash": "allow"
  }
}
