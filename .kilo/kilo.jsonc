{
  "$schema": "https://app.kilo.ai/config.json",
  "username": "BLE Engineer",
  "default_agent": "ble-engineer",
  "model": "anthropic/claude-sonnet-4-20250514",
  "instructions": [
    "AGENTS.md",
    ".kilo/instructions/*.md"
  ],
  "auto_collapse_reasoning": true,
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "question": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "task": {
      "*": "allow",
      "ble-engineer": "allow",
      "gatt-recovery": "allow",
      "russian-dev": "allow"
    },
    "bash": {
      "*": "allow",
      "sudo apt*": "ask",
      "sudo rm *": "deny"
    }
  }
}
