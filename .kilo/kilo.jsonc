{
  "$schema": "https://app.kilo.ai/config.json",
  "username": "BLE Engineer",
  "default_agent": "ble-engineer",
  "model": "anthropic/claude-sonnet-4-20250514",
  "instructions": [
    "AGENTS.md",
    ".kilo/instructions/*.md",
    "~/.config/kilo/AGENTS.md"
  ],
  "auto_collapse_reasoning": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
    "tail_turns": 2
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "question": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "task": {
      "*": "allow",
      "ble-engineer": "allow",
      "gatt-recovery": "allow",
      "russian-dev": "allow",
      "reviewer": "allow",
      "planner": "allow",
      "debugger": "allow",
      "doc-scribe": "allow",
      "sys-inspector": "allow",
      "log-analyzer": "allow",
      "adb-specialist": "allow",
      "esp32-arduino-specialist": "allow",
      "apk-reverse-engineer": "allow"
    },
    "bash": {
      "*": "allow",
      "sudo apt*": "ask",
      "sudo rm *": "deny"
    }
  },
}
