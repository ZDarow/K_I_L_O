#!/usr/bin/env bash
# ============================================
# Pre-commit hook — делегирование pre-commit
# ============================================
# Этот хук установлен через make git-hooks.
# Для полной проверки (24 хука) используйте pre-commit install.

set -euo pipefail

if command -v pre-commit &>/dev/null; then
    exec pre-commit run --hook-stage commit
fi

# Fallback: базовая проверка shell-синтаксиса
errors=0
for f in $(git diff --cached --name-only); do
    case "$f" in
        *.sh|*.bash|*.bats)
            if ! bash -n "$f" 2>/dev/null; then
                echo "[✗] $f: синтаксическая ошибка shell"
                errors=$((errors + 1))
            fi
            ;;
    esac
done

if [ "$errors" -gt 0 ]; then
    echo "Pre-commit: $errors ошибок. Коммит отменён."
    echo "Установи pre-commit: pip install pre-commit && pre-commit install"
    exit 1
fi
exit 0
